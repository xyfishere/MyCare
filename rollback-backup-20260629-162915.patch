+function resetFamilyState() {
+  familyState = {
+    loading: false,
+    activeFamily: null,
+    membership: null,
+    members: [],
+    invitations: [],
+    goals: [],
+    error: "",
+  };
+}
+
+function getFamilyCategories() {
+  const fallback = ["Home", "Health", "Together"];
+  const raw = familyState.activeFamily?.category_options;
+  const source = Array.isArray(raw) && raw.length ? raw : fallback;
+  const seen = new Set();
+  return source
+    .map((item) => String(item || "").trim())
+    .filter((item) => {
+      const key = item.toLowerCase();
+      if (!item || seen.has(key)) return false;
+      seen.add(key);
+      return true;
+    })
+    .slice(0, 12);
+}
+
+function renderFamilyCategoryControls() {
+  const text = familyText();
+  const fallback = {
+    customizeCategories: "Customize categories",
+    categorySettingsTitle: "Family categories",
+    categorySettingsMeta: "Shared only inside this family.",
+    categoryInputPlaceholder: "New category",
+    categoryAdd: "Add",
+  };
+  const categories = getFamilyCategories();
+  const select = $("#familyGoalCategory");
+  if (select) {
+    const currentValue = select.value;
+    select.innerHTML = categories
+      .map((category) => `<option value="${escapeHtml(category)}">${escapeHtml(category)}</option>`)
+      .join("");
+    if (categories.includes(currentValue)) select.value = currentValue;
+  }
+  $("#familyCategoryCustomizeButton").textContent = text.customizeCategories || fallback.customizeCategories;
+  $("#familyCategorySettingsTitle").textContent = text.categorySettingsTitle || fallback.categorySettingsTitle;
+  $("#familyCategorySettingsMeta").textContent = text.categorySettingsMeta || fallback.categorySettingsMeta;
+  $("#familyCategoryInput").placeholder = text.categoryInputPlaceholder || fallback.categoryInputPlaceholder;
+  $("#familyCategoryAddButton").textContent = text.categoryAdd || fallback.categoryAdd;
+  $("#familyCategoryList").innerHTML = categories.map((category) => `
+    <button class="family-category-chip" data-family-category="${escapeHtml(category)}" type="button">
+      <span>${escapeHtml(category)}</span>
+      <b aria-hidden="true">×</b>
+    </button>
+  `).join("");
+}
+
+function renderFamilyUrgencyOptions() {
+  const text = familyText();
+  const labels = {
+    low: text.urgencyLow || "Low",
+    normal: text.urgencyNormal || "Normal",
+    urgent: text.urgencyUrgent || "Urgent",
+  };
+  $("#familyUrgencyLabel").textContent = text.urgency || "Urgency";
+  $$(".family-urgency-option").forEach((button) => {
+    const urgency = button.dataset.familyUrgency || "normal";
+    button.textContent = labels[urgency] || urgency;
+    button.classList.toggle("active", urgency === selectedFamilyGoalUrgency);
+    button.setAttribute("aria-pressed", String(urgency === selectedFamilyGoalUrgency));
+  });
+}
+
+async function saveFamilyCategories(categories) {
+  if (!supabaseClient || !currentUser || !familyState.activeFamily) return;
+  const cleaned = categories
+    .map((item) => String(item || "").trim())
+    .filter(Boolean)
+    .slice(0, 12);
+  setFamilyMessage(familyText().loading);
+  const { data, error } = await supabaseClient.rpc("update_family_categories", {
+    target_family_id: familyState.activeFamily.id,
+    categories: cleaned,
+  });
+  if (error) {
+    setFamilyMessage(error.message, true);
+    return;
+  }
+  familyState.activeFamily.category_options = Array.isArray(data) ? data : cleaned;
+  renderFamilyCategoryControls();
+  setFamilyMessage("");
+}
+
+async function addFamilyCategory(event) {
+  event.preventDefault();
+  const input = $("#familyCategoryInput");
+  const value = input?.value.trim();
+  if (!value) return;
+  const categories = getFamilyCategories();
+  if (!categories.some((category) => category.toLowerCase() === value.toLowerCase())) {
+    await saveFamilyCategories([...categories, value]);
+  }
+  if (input) input.value = "";
+}
+
+async function removeFamilyCategory(event) {
+  const button = event.target.closest("[data-family-category]");
+  if (!button) return;
+  const category = button.dataset.familyCategory;
+  const categories = getFamilyCategories().filter((item) => item !== category);
+  await saveFamilyCategories(categories);
+}
