+create or replace function public.create_family(family_name text)
+returns uuid
+language plpgsql
+security definer
+set search_path = public
+as $$
+declare
+  new_family_id uuid;
+  member_email text;
+begin
+  if auth.uid() is null then
+    raise exception 'Authentication required';
+  end if;
+
+  if char_length(trim(family_name)) < 1 or char_length(trim(family_name)) > 60 then
+    raise exception 'Family name must be between 1 and 60 characters';
+  end if;
+
+  member_email := lower(coalesce(auth.jwt() ->> 'email', ''));
+
+  insert into public.families (name, owner_id)
+  values (trim(family_name), auth.uid())
+  returning id into new_family_id;
+
+  insert into public.family_members (family_id, user_id, email, role)
+  values (new_family_id, auth.uid(), member_email, 'owner');
+
+  return new_family_id;
+end;
+$$;
+
+create or replace function public.accept_family_invitation(invitation_id uuid)
+returns uuid
+language plpgsql
+security definer
+set search_path = public
+as $$
+declare
+  invitation public.family_invitations%rowtype;
+  member_email text;
+begin
+  if auth.uid() is null then
+    raise exception 'Authentication required';
+  end if;
+
+  member_email := lower(coalesce(auth.jwt() ->> 'email', ''));
+
+  select *
+  into invitation
+  from public.family_invitations
+  where id = invitation_id
+    and status = 'pending'
+    and lower(email) = member_email
+  for update;
+
+  if invitation.id is null then
+    raise exception 'Invitation not found';
+  end if;
+
+  insert into public.family_members (family_id, user_id, email, role)
+  values (invitation.family_id, auth.uid(), member_email, 'member')
+  on conflict (family_id, user_id) do nothing;
+
+  update public.family_invitations
+  set status = 'accepted',
+      accepted_at = now()
+  where id = invitation.id;
+
+  return invitation.family_id;
+end;
+$$;
+
+create or replace function public.touch_family_goal()
+returns trigger
+language plpgsql
+set search_path = public
+as $$
+begin
+  new.updated_at = now();
+  if new.status = 'done' and old.status <> 'done' then
+    new.completed_at = now();
+    new.completed_by = auth.uid();
+  elsif new.status <> 'done' then
+    new.completed_at = null;
+    new.completed_by = null;
+  end if;
+  return new;
+end;
+$$;
+
+drop trigger if exists touch_family_goal_before_update on public.family_goals;
+create trigger touch_family_goal_before_update
+before update on public.family_goals
+for each row execute function public.touch_family_goal();
+
+revoke all on function public.create_family(text) from public;
+revoke all on function public.accept_family_invitation(uuid) from public;
+grant execute on function public.create_family(text) to authenticated;
+grant execute on function public.accept_family_invitation(uuid) to authenticated;
